<Page
    x:Class="Ghostty.Settings.Pages.RawEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyboardAcceleratorPlacementMode="Hidden">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="CtrlF_Invoked" />
        <KeyboardAccelerator Key="F3" Invoked="F3_Invoked" />
        <KeyboardAccelerator Key="F3" Modifiers="Shift" Invoked="ShiftF3_Invoked" />
    </Page.KeyboardAccelerators>

    <Page.Resources>
        <!--
          Inline "code pill" styles for the Windows-only keys list. Kept as
          XAML Styles so the ThemeResource brushes re-resolve when the OS
          theme flips while the Settings window is open; a code-behind
          snapshot via Application.Current.Resources[...] would paint with
          whatever theme was active at build time (see devhome #3329).
        -->
        <Style x:Key="CodePillBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,1,6,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CodePillTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>
    </Page.Resources>

    <Grid Padding="24" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">
        <TextBlock Text="Raw Config Editor" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <!-- Find bar (Ctrl+F) -->
        <Border x:Name="FindBar"
            Grid.Row="1"
            Visibility="Collapsed"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8,6"
            Margin="0,0,0,8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                <TextBox x:Name="FindInput"
                    PlaceholderText="Find..."
                    AcceptsReturn="False"
                    IsSpellCheckEnabled="False"
                    TextChanged="FindInput_TextChanged"
                    KeyDown="FindInput_KeyDown"
                    Padding="6,4" />
                <TextBlock x:Name="FindMatchCount"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="8,0,4,0"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ToggleButton x:Name="FindCaseSensitive"
                    Grid.Column="2"
                    Content="Aa"
                    FontSize="11"
                    VerticalAlignment="Center"
                    Padding="6,3"
                    MinWidth="0"
                    ToolTipService.ToolTip="Match case"
                    Click="FindCaseSensitive_Click" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2" Margin="4,0">
                    <Button Click="FindPrev_Click" ToolTipService.ToolTip="Previous (Shift+Enter)" Padding="6,4">
                        <FontIcon Glyph="&#xE70E;" FontSize="10" />
                    </Button>
                    <Button Click="FindNext_Click" ToolTipService.ToolTip="Next (Enter)" Padding="6,4">
                        <FontIcon Glyph="&#xE70D;" FontSize="10" />
                    </Button>
                </StackPanel>
                <Button Grid.Column="4" Click="FindClose_Click" ToolTipService.ToolTip="Close (Esc)" Padding="6,4">
                    <FontIcon Glyph="&#xE894;" FontSize="10" />
                </Button>
            </Grid>
        </Border>

        <RichEditBox
            x:Name="Editor"
            Grid.Row="2"
            TextWrapping="NoWrap"
            FontFamily="Cascadia Code, Consolas, monospace"
            FontSize="13"
            IsSpellCheckEnabled="False"
            KeyDown="Editor_KeyDown"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Auto" />

        <Expander
            x:Name="WindowsOnlyExpander"
            Grid.Row="3"
            Margin="0,12,0,0"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Visibility="Collapsed">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon
                        Glyph="&#xE946;"
                        FontSize="16"
                        Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                        VerticalAlignment="Center" />
                    <TextBlock Text="Windows-only settings in use" VerticalAlignment="Center" />
                    <InfoBadge x:Name="WindowsOnlyCountBadge" VerticalAlignment="Center" />
                </StackPanel>
            </Expander.Header>
            <!-- RichTextBlock assigned from code-behind; see RefreshWindowsOnlyInfo. -->
            <ContentControl x:Name="WindowsOnlyContentSlot" HorizontalContentAlignment="Stretch" />
        </Expander>

        <Expander
            x:Name="DiagnosticsExpander"
            Grid.Row="4"
            Margin="0,12,0,0"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!--
                      Status glyph: check when clean, X when errors.
                      Uses Segoe Fluent Icons (CheckMark E73E, Cancel E711)
                      with theme-aware brushes that adapt to light/dark.
                    -->
                    <FontIcon
                        x:Name="StatusOkIcon"
                        Glyph="&#xE73E;"
                        FontSize="16"
                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                        VerticalAlignment="Center" />
                    <FontIcon
                        x:Name="StatusErrorIcon"
                        Glyph="&#xE711;"
                        FontSize="16"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
                    <TextBlock x:Name="StatusLabel" Text="No issues" VerticalAlignment="Center" />
                    <InfoBadge x:Name="CountBadge" VerticalAlignment="Center" />
                </StackPanel>
            </Expander.Header>
            <Grid>
                <ListView
                    x:Name="DiagList"
                    SelectionMode="None"
                    MaxHeight="180">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <!-- Text set from ContainerContentChanging (AOT-safe,
                                 avoids reflection-based {Binding}). Selection
                                 enabled so users can copy diagnostic text. -->
                            <TextBlock FontFamily="Cascadia Code, Consolas, monospace"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock
                    x:Name="DiagEmptyState"
                    Text="All good, nothing to see here"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontStyle="Italic"
                    Padding="12"
                    Visibility="Collapsed" />
            </Grid>
        </Expander>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
            <Button Content="Save and Reload" Style="{StaticResource AccentButtonStyle}" Click="SaveButton_Click" />
            <Button Content="Revert" Click="RevertButton_Click" />
            <Button Content="Reload" Click="ReloadButton_Click" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0" />
        </StackPanel>
    </Grid>
</Page>

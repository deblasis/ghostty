<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Ghostty.Tabs.TabHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:branding="using:Ghostty.Branding"
    xmlns:tabs="using:Ghostty.Tabs"
    RequestedTheme="Dark"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">
    <!--
        Two-row layout:
        - Row 0: TabView used ONLY as a tab strip (TabViewItem.Content
          is null on every item). The strip handles drag-reorder, the
          add/close X buttons, and the visual tab UI.
        - Row 1: PaneHostContainer is a Grid that owns the active tab's
          PaneHost AS A SIBLING of every other tab's PaneHost. All
          PaneHosts live here from creation to close; only Visibility
          toggles when the active tab changes. They are NEVER reparented.

        Why: TerminalControl's SwapChainPanel binds the libghostty
        surface to a DXGI swap chain via SetSwapChain ONCE at SurfaceNew
        time and never re-binds. If WinUI 3 unloads the SwapChainPanel
        (which happens whenever its parent's content presenter swaps,
        including during TabView's initial layout), the underlying
        DirectComposition visual is torn down and recreated with no
        swap chain attached. Frames continue rendering into the
        original DXGI swap chain — completely invisible because the new
        DCOMP visual has nothing to compose. The renderer log looks
        healthy ("screen size = 800x600"), the build is clean, but the
        screen is black.

        Toggling Visibility on a sibling does NOT fire Unloaded, so
        the swap chain attachment survives indefinitely. This matches
        the pattern VerticalTabStrip will use in plan 2.
    -->
    <!-- PaneHostContainer used to live here as Row 1 but the runtime
         layout switch (#171) moved it up to MainWindow.RootGrid so
         both tab hosts can share a single container without ever
         reparenting the SwapChainPanels. This UserControl now renders
         only the tab strip chrome. -->
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top">
        <controls:TabView
            x:Name="TabViewControl"
            HorizontalAlignment="Stretch"
            CanReorderTabs="True"
            CanDragTabs="True"
            TabWidthMode="Equal"
            IsAddTabButtonVisible="False"
            TabCloseRequested="OnTabCloseRequested"
            ContextRequested="OnTabViewContextRequested"
            SelectionChanged="OnSelectionChanged"
            TabDragCompleted="OnTabDragCompleted">
            <controls:TabView.Resources>
                <!--
                    Inactive tabs default to near-transparent in WinUI 3,
                    making them indistinguishable from the Mica/theme
                    background. LayerFillColorDefaultBrush is the WinUI 3
                    design token for "subtle layer over a Mica/acrylic
                    surface" and resolves per-theme (Light, Dark, custom
                    Wintty themes) automatically. The selected-tab brush
                    continues to be overridden in code-behind
                    (ApplyShellTheme) with the user's accent color; that
                    path only touches TabViewItemHeaderBackgroundSelected
                    and does not conflict with these unselected overrides.
                -->
                <StaticResource x:Key="TabViewItemHeaderBackground"
                                ResourceKey="LayerFillColorDefaultBrush"/>
                <StaticResource x:Key="TabViewItemHeaderBackgroundPointerOver"
                                ResourceKey="LayerOnAcrylicFillColorDefaultBrush"/>
                <StaticResource x:Key="TabViewItemHeaderBackgroundPressed"
                                ResourceKey="LayerOnAcrylicFillColorDefaultBrush"/>
            </controls:TabView.Resources>
            <controls:TabView.TabStripHeader>
                <branding:AppIconBadge />
            </controls:TabView.TabStripHeader>
            <!--
                TabStripFooter is a two-cell row. Cell 0 holds the
                NewTabSplitButton (not inside the drag region so clicks
                land on the button). Cell 1 is the drag-only spacer
                named CustomDragRegion; MainWindow calls
                SetTitleBar(CustomDragRegion) so the empty strip area
                still drags the window.
            -->
            <controls:TabView.TabStripFooter>
                <Grid x:Name="FooterRoot">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Cell 0: composite new-tab control. NOT inside the
                         drag region; clicks reach the SplitButton. -->
                    <tabs:NewTabSplitButton x:Name="NewTabButton"
                                            Grid.Column="0"
                                            Margin="4,0,4,0"/>
                    <!-- Cell 1: drag-only spacer. Owns the title-bar
                         passthrough so the empty strip area still drags
                         the window. MinWidth reserves room for the OS
                         caption buttons (min/max/close) at 100% scale.
                         TODO(titlebar): bind MinWidth to
                         AppWindow.TitleBar.RightInset / RasterizationScale. -->
                    <Grid x:Name="CustomDragRegion"
                          Grid.Column="1"
                          MinWidth="146"
                          Background="Transparent"/>
                </Grid>
            </controls:TabView.TabStripFooter>
        </controls:TabView>
    </Grid>
</UserControl>

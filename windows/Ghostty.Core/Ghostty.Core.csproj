<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!--
      Plain net9.0. No Windows App SDK targets, no PRI/MRT, no WinUI.
      This assembly holds pure-logic types that both the WinUI shell
      (Ghostty.csproj) and the test project (Ghostty.Tests.csproj)
      reference normally via ProjectReference.

      Goal: tests run against the real production types, not against
      hand-written stubs that drift. The previous PaneStubs.cs +
      Compile Include trick is replaced by this assembly.
    -->
    <TargetFramework>net9.0</TargetFramework>
    <RootNamespace>Ghostty.Core</RootNamespace>
    <AssemblyName>Ghostty.Core</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <!--
      IsAotCompatible is the composite library-project knob that flips
      EnableTrimAnalyzer, EnableAotAnalyzer, EnableSingleFileAnalyzer,
      and IsTrimmable together. TrimmerSingleWarn=false expands the
      default per-assembly aggregate rollup into per-callsite diagnostics
      so future warnings land with actionable locations. Issue # 204.
    -->
    <IsAotCompatible>true</IsAotCompatible>
    <TrimmerSingleWarn>false</TrimmerSingleWarn>
    <!--
      Required by Ghostty.Core.DirectWrite.DWriteFontEnumerator's
      raw-vtable reference path. The migrated CsWin32 path also uses
      stackalloc + PWSTR in unsafe blocks, so this applies to both
      enumeration helpers.
    -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
</Project>
